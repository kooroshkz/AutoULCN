{
  "manifest_version": 3,
  "name": "AutoULCN",
  "version": "4.0",
  "description": "Generates your Leiden University TOTP code and fills it on the ULCN/MFA login pages.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://login.uaccess.leidenuniv.nl/*",
        "*://mfa.services.universiteitleiden.nl/*",
        "*://account.services.universiteitleiden.nl/portaal/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "autoulcnfirefox@kooroshkz.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
